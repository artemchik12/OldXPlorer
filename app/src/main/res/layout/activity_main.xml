<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <!-- Top Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="#3F51B5"
        android:gravity="center_vertical"
        android:paddingLeft="8dp"
        android:paddingRight="8dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="36dp"
            android:layout_height="36dp"
            app:srcCompat="@drawable/ic_back"
            android:padding="6dp"
            android:contentDescription="Back" />

        <ImageView
            android:id="@+id/btnUp"
            android:layout_width="36dp"
            android:layout_height="36dp"
            app:srcCompat="@drawable/ic_up"
            android:padding="6dp"
            android:contentDescription="Up" />

        <ImageView
            android:id="@+id/btnHome"
            android:layout_width="36dp"
            android:layout_height="36dp"
            app:srcCompat="@drawable/ic_home"
            android:padding="6dp"
            android:contentDescription="Home" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="File Manager"
            android:textColor="#FFFFFF"
            android:textSize="17sp"
            android:textStyle="bold"
            android:gravity="center"
            android:singleLine="true" />

        <ImageView
            android:id="@+id/btnMore"
            android:layout_width="36dp"
            android:layout_height="36dp"
            app:srcCompat="@drawable/ic_more"
            android:padding="6dp"
            android:contentDescription="More" />
    </LinearLayout>

    <!-- Current Path -->
    <TextView
        android:id="@+id/tvCurrentPath"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="8dp"
        android:textSize="11sp"
        android:background="#E8E8E8"
        android:singleLine="true"
        android:ellipsize="start"
        android:textColor="#555555" />

    <!-- Action Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:orientation="horizontal"
        android:padding="2dp"
        android:background="#EEEEEE">

        <ImageView
            android:id="@+id/btnNewFolder"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            app:srcCompat="@drawable/ic_new_folder"
            android:padding="8dp"
            android:contentDescription="New folder" />

        <ImageView
            android:id="@+id/btnSearch"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            app:srcCompat="@drawable/ic_search"
            android:padding="8dp"
            android:contentDescription="Search" />

        <ImageView
            android:id="@+id/btnSort"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            app:srcCompat="@drawable/ic_sort"
            android:padding="8dp"
            android:contentDescription="Sort" />

        <ImageView
            android:id="@+id/btnStorage"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            app:srcCompat="@drawable/ic_sd_card"
            android:padding="8dp"
            android:contentDescription="Storage" />

        <ImageView
            android:id="@+id/btnPaste"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            app:srcCompat="@drawable/ic_paste"
            android:padding="8dp"
            android:visibility="gone"
            android:contentDescription="Paste" />
    </LinearLayout>

    <!-- Clipboard info -->
    <TextView
        android:id="@+id/tvClipboard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="6dp"
        android:textSize="11sp"
        android:background="#FFF9C4"
        android:textColor="#F57F17"
        android:visibility="gone"
        android:singleLine="true" />

    <!-- Progress Bar -->
    <ProgressBar
        android:id="@+id/progressBar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:indeterminate="true"
        android:visibility="gone" />

    <!-- File List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Empty State -->
    <TextView
        android:id="@+id/tvEmpty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Empty folder"
        android:gravity="center"
        android:visibility="gone"
        android:padding="48dp"
        android:textSize="16sp"
        android:textColor="#AAAAAA" />

    <!-- Bottom Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="8dp"
        android:background="#E0E0E0"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tvFileCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="#666666"
            android:text="0 items" />
    </LinearLayout>

</LinearLayout>
